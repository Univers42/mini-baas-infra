# Fly deployment service map.
# Format: logical_service=config_file:default_app_suffix
# Actual app name is ${FLY_APP_PREFIX}-${suffix}; default FLY_APP_PREFIX=mini-baas.

adapter-registry=adapter-registry.fly.toml:adapter-registry
mongo-api=mongo-api.fly.toml:mongo-api
auth=auth.fly.toml:auth
postgrest=postgrest.fly.toml:postgrest
permission-engine=permission-engine.fly.toml:permission-engine
schema-service=schema-service.fly.toml:schema-service
query-router=query-router.fly.toml:query-router
storage-router=storage-router.fly.toml:storage-router
email-service=email-service.fly.toml:email-service
analytics-service=analytics-service.fly.toml:analytics-service
gdpr-service=gdpr-service.fly.toml:gdpr-service
newsletter-service=newsletter-service.fly.toml:newsletter-service
ai-service=ai-service.fly.toml:ai-service
log-service=log-service.fly.toml:log-service
session-service=session-service.fly.toml:session-service
realtime=realtime.fly.toml:realtime
gateway=gateway.fly.toml:gateway
