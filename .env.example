# File: .env.example
# mini-BaaS environment configuration
# Copy to .env and fill in values, or run: bash scripts/generate-env.sh .env
#
# WARNING: Never commit .env with real secrets to version control.

# ═══════════════════════════════════════════
# Core Database
# ═══════════════════════════════════════════
POSTGRES_USER=postgres
POSTGRES_PASSWORD=           # REPLACE: openssl rand -hex 16
POSTGRES_DB=postgres
DATABASE_URL=postgres://postgres:PASSWORD@postgres:5432/postgres
PGRST_DB_URI=postgres://postgres:PASSWORD@postgres:5432/postgres

# ═══════════════════════════════════════════
# WAF (public HTTP entrypoint)
# ═══════════════════════════════════════════
WAF_HTTP_PORT=8880             # Host port for WAF reverse proxy (default: 8880)

# ═══════════════════════════════════════════
# Kong Gateway
# ═══════════════════════════════════════════
# Kong key-auth credentials must be the same JWTs as ANON_KEY / SERVICE_ROLE_KEY
# because supabase-js sends them as both apikey and Authorization: Bearer.
KONG_PUBLIC_API_KEY=<ANON_KEY_JWT>
KONG_SERVICE_API_KEY=<SERVICE_ROLE_KEY_JWT>
KONG_CORS_ORIGIN_APP=http://localhost:3000
KONG_CORS_ORIGIN_PLAYGROUND=http://localhost:3100
KONG_CORS_ORIGIN_STUDIO=http://localhost:3001

# ═══════════════════════════════════════════
# Authentication (GoTrue)
# ═══════════════════════════════════════════
API_EXTERNAL_URL=http://localhost:8000/auth/v1
GOTRUE_SITE_URL=http://localhost:5173
GOTRUE_URI_ALLOW_LIST=http://localhost:5173/**
JWT_SECRET=                  # REPLACE: openssl rand -hex 32

# ═══════════════════════════════════════════
# PostgREST
# ═══════════════════════════════════════════
PGRST_DB_SCHEMA=public
PGRST_DB_ANON_ROLE=anon

# ═══════════════════════════════════════════
# Realtime (dlesieur/realtime-agnostic)
# ═══════════════════════════════════════════
# All REALTIME_* vars are set in docker-compose.yml environment: block.
# JWT_SECRET is reused from the Authentication section above.
# The engine LISTENs on the PG channel defined by REALTIME_PG_CHANNEL
# and watches MongoDB via Change Streams on REALTIME_MONGO_DB.
RUST_LOG=info                # debug | info | warn | error

# ═══════════════════════════════════════════
# Supabase API Keys (HS256 JWTs)
# ═══════════════════════════════════════════
ANON_KEY=                    # Generated by generate-env.sh
SERVICE_ROLE_KEY=            # Generated by generate-env.sh

# ═══════════════════════════════════════════
# MinIO (Object Storage)
# ═══════════════════════════════════════════
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=         # REPLACE: openssl rand -hex 16

# ═══════════════════════════════════════════
# Supavisor (Connection Pooler)
# ═══════════════════════════════════════════
VAULT_ENC_KEY=               # REPLACE: openssl rand -hex 16

# ═══════════════════════════════════════════
# Studio (Admin Dashboard)
# ═══════════════════════════════════════════
STUDIO_PG_META_URL=http://host.docker.internal:8080
SUPABASE_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

# ═══════════════════════════════════════════
# MongoDB
# ═══════════════════════════════════════════
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=mini_baas

# ═══════════════════════════════════════════
# Adapter Registry (NEW)
# ═══════════════════════════════════════════
ADAPTER_REGISTRY_DATABASE_URL=postgres://postgres:PASSWORD@postgres:5432/postgres

# ═══════════════════════════════════════════
# Query Router (NEW)
# ═══════════════════════════════════════════
ADAPTER_REGISTRY_URL=http://adapter-registry:3020

# ═══════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════
LOG_LEVEL=info               # debug | info | warn | error

# ═══════════════════════════════════════════
# Analytics Service
# ═══════════════════════════════════════════
ANALYTICS_MONGO_DB=mini_baas_analytics
ANALYTICS_RETENTION_DAYS=90

# ═══════════════════════════════════════════
# GDPR Service
# ═══════════════════════════════════════════
GDPR_DELETION_WEBHOOK_URL=   # URL called on deletion completion (consuming app provides this)
GDPR_EXPORT_WEBHOOK_URL=     # URL called to assemble user data export

# ═══════════════════════════════════════════
# Newsletter Service
# ═══════════════════════════════════════════
NEWSLETTER_BATCH_SIZE=5      # Emails per batch when sending campaigns

# ═══════════════════════════════════════════
# AI Service
# ═══════════════════════════════════════════
AI_MONGO_DB=mini_baas_ai
LLM_API_URL=https://api.groq.com/openai/v1
LLM_API_KEY=                 # REPLACE: your LLM provider API key
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
AI_CONVERSATION_TTL_HOURS=24

# ═══════════════════════════════════════════
# Log Service
# ═══════════════════════════════════════════
LOG_BUFFER_SIZE=1000
LOG_STREAM_TOKEN=            # REPLACE: openssl rand -hex 16 (token for SSE stream auth)

# ═══════════════════════════════════════════
# Session Service
# ═══════════════════════════════════════════
SESSION_TTL_DAYS=7
