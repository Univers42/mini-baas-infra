# Copy to .env and replace placeholders for real environments.

# Core database connection used by multiple services
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DATABASE_URL=postgres://postgres:postgres@postgres:5432/postgres
PGRST_DB_URI=postgres://postgres:postgres@postgres:5432/postgres

# Kong (single entrypoint)
KONG_PROXY_URL=http://localhost:8000
KONG_ADMIN_URL=http://localhost:8001

# GoTrue
API_EXTERNAL_URL=http://localhost:9999
GOTRUE_SITE_URL=http://localhost:3001
JWT_SECRET=replace-with-32-plus-char-secret

# PostgREST
PGRST_DB_SCHEMA=public
PGRST_DB_ANON_ROLE=postgres

# Realtime
REALTIME_DB_HOST=postgres
REALTIME_DB_PORT=5432
REALTIME_DB_USER=postgres
REALTIME_DB_PASSWORD=postgres
REALTIME_DB_NAME=realtime
REALTIME_APP_NAME=realtime-dev
REALTIME_DASHBOARD_USER=supabase
REALTIME_DASHBOARD_PASSWORD=replace-with-strong-password
SECRET_KEY_BASE=replace-with-long-random-secret
METRICS_JWT_SECRET=replace-with-32-plus-char-secret
# API_JWT_SECRET defaults to JWT_SECRET in docker-compose
ANON_KEY=replace-with-valid-jwt-or-public-anon-token
SERVICE_ROLE_KEY=replace-with-valid-jwt-service-role-token

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-password

# Supavisor
# Reuse SECRET_KEY_BASE defined above
VAULT_ENC_KEY=replace-with-32-char-encryption-key

# Studio
STUDIO_PG_META_URL=http://host.docker.internal:8080
SUPABASE_URL=http://localhost:9999
SUPABASE_PUBLIC_URL=http://localhost:9999
# Studio uses ANON_KEY and SERVICE_ROLE_KEY above
